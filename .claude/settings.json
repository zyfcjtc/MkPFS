{
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(./run-tests.sh)",
      "WebSearch",
      "Bash(python -m twine check dist/*)",
      "Bash(uv build:*)",
      "Bash(python3.11 --version)",
      "Bash(git status:*)"
    ]
  },
  "autoFix": {
    "enabled": true,
    "format": "uv run --frozen ruff format .",
    "lint": "uv run --frozen ruff check . --fix",
    "test": "uv run --frozen pytest",
    "maxRetries": 3,
    "timeout": 60000
  }
}
